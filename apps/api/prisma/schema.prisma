generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

enum AccountType {
  personal
  business
  shared
  investment
}

enum AccountRole {
  owner
  editor
  viewer
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

enum ReferralStatus {
  pending
  qualified
  expired

  @@map("referral_status")
}

model Referral {
  id             String         @id @default(uuid())
  referrerUserId String         @map("referrer_user_id")
  referredUserId String         @unique @map("referred_user_id")
  code           String         @map("code")
  status         ReferralStatus @default(pending)
  bonusGranted   Boolean        @default(false) @map("bonus_granted")
  qualifiedAt    DateTime?      @map("qualified_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  referrer User @relation("ReferralsMade", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredBy", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([status, createdAt])
  @@map("referrals")
}

enum SubscriptionTier {
  free
  pro
  business
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  incomplete
  trialing
  paused
}

enum AppPlatform {
  ios
  android

  @@map("app_platform")
}

// ---- Models ----

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  name             String
  currencyCode     String    @default("USD") @map("currency_code")
  timezone         String    @default("UTC")
  language             String    @default("en")
  pushToken            String?   @map("push_token")
  notifyBudgetAlerts      Boolean   @default(true) @map("notify_budget_alerts")
  notifySharedActivity    Boolean   @default(true) @map("notify_shared_activity")
  notifyDebtReminders     Boolean   @default(true) @map("notify_debt_reminders")
  notifyRecurringExpenses Boolean   @default(true) @map("notify_recurring_expenses")
  notifySubscriptionRenewals Boolean @default(true) @map("notify_subscription_renewals")
  notifyAnomalyAlerts     Boolean   @default(true) @map("notify_anomaly_alerts")
  isActive             Boolean   @default(true) @map("is_active")
  isVerified           Boolean   @default(false) @map("is_verified")
  emailVerificationCode      String?   @map("email_verification_code")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  defaultAccountId String?   @map("default_account_id")
  lastSyncAt       DateTime? @map("last_sync_at")
  passwordResetCode      String?   @map("password_reset_code")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  emailChangePending     String?   @map("email_change_pending")
  emailChangeCode        String?   @map("email_change_code")
  emailChangeExpiresAt   DateTime? @map("email_change_expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  referralCode   String?    @unique @map("referral_code")
  referralsMade  Referral[] @relation("ReferralsMade")
  referredBy     Referral?  @relation("ReferredBy")

  // Relations
  expenses          Expense[]
  incomes           Income[]
  budgets           Budget[]
  categories        Category[]
  chatConversations ChatConversation[]
  budgetAlerts      BudgetAlert[]
  syncLogs          SyncLog[]
  ownedAccounts     Account[]          @relation("OwnedAccounts")
  accountMembers    AccountMember[]
  walletBalances    WalletBalance[]
  currencyExchanges CurrencyExchange[]
  accountTransfers  AccountTransfer[]
  subscription      Subscription?
  usageLogs         UsageLog[]
  achievements      UserAchievement[]
  streaks           UserStreak[]
  portfolioHoldings       PortfolioHolding[]
  investmentTransactions  InvestmentTransaction[]
  encryptionProfile       UserEncryptionProfile?
  accountEncryptionKeys   AccountEncryptionKey[]

  // AI preferences
  aiResponseMode        String    @default("balanced") @map("ai_response_mode")
  aiModel               String    @default("balanced") @map("ai_model")

  // Report preferences
  weeklyEmailEnabled    Boolean   @default(false) @map("weekly_email_enabled")
  weeklyEmailDay        Int       @default(1)     @map("weekly_email_day")
  monthlyDigestEnabled  Boolean   @default(false) @map("monthly_digest_enabled")

  // Report & backup relations
  generatedReports      GeneratedReport[]
  backupHistory         BackupHistory[]
  savingsGoals          SavingsGoal[]

  // Admin panel relations
  adminAuditLogs          AdminAuditLog[]
  adminNotificationLogs   NotificationLog[]
  adminScheduledNotifications ScheduledNotification[]

  // Telegram
  telegramLink      TelegramLink?
  telegramLinkCodes TelegramLinkCode[]

  // WhatsApp
  whatsappLink      WhatsAppLink?
  whatsappLinkCodes WhatsAppLinkCode[]

  // Slack
  slackLink      SlackLink?
  slackLinkCodes SlackLinkCode[]

  importBatches     ImportBatch[]

  @@map("users")
}

model Account {
  id                String      @id @default(uuid())
  name              String
  type              AccountType
  currencyCode      String      @default("USD") @map("currency_code")
  ownerId           String      @map("owner_id")
  icon              String?
  isActive          Boolean     @default(true) @map("is_active")
  encryptionEnabled Boolean     @default(false) @map("encryption_enabled")
  encryptionTier    Int         @default(0) @map("encryption_tier")
  keyRotationNeeded Boolean     @default(false) @map("key_rotation_needed")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  owner       User                @relation("OwnedAccounts", fields: [ownerId], references: [id], onDelete: Cascade)
  members     AccountMember[]
  invitations AccountInvitation[]
  expenses    Expense[]
  incomes     Income[]
  budgets     Budget[]
  categories        Category[]
  syncLogs          SyncLog[]
  walletBalances    WalletBalance[]
  currencyExchanges CurrencyExchange[]
  transfersOut      AccountTransfer[] @relation("TransfersOut")
  transfersIn       AccountTransfer[] @relation("TransfersIn")
  usageLogs         UsageLog[]
  generatedInsights GeneratedInsight[]
  spendingStories   SpendingStory[]
  tags              Tag[]
  projects          Project[]
  achievements      UserAchievement[]
  streaks           UserStreak[]
  portfolioHoldings       PortfolioHolding[]
  investmentTransactions  InvestmentTransaction[]
  encryptionKeys          AccountEncryptionKey[]
  generatedReports        GeneratedReport[]
  backupHistory           BackupHistory[]
  monthlyDigestCache      MonthlyDigestCache[]
  savingsGoals            SavingsGoal[]
  fatFinderReports        FatFinderReport[]
  telegramLinks           TelegramLink[]
  whatsappLinks           WhatsAppLink[]
  slackLinks              SlackLink[]
  csvImportMappings       CsvImportMapping[]
  chatConversations       ChatConversation[]
  importBatches           ImportBatch[]
  userSubscriptions       UserSubscription[]
  anomalyAlerts           AnomalyAlert[]
  merchantCategoryRules   MerchantCategoryRule[]
  goalContributions       GoalContribution[]

  @@map("accounts")
}

model AccountMember {
  id        String      @id @default(uuid())
  accountId String      @map("account_id")
  userId    String      @map("user_id")
  role      AccountRole
  joinedAt  DateTime    @default(now()) @map("joined_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("account_members")
}

model AccountInvitation {
  id           String           @id @default(uuid())
  accountId    String           @map("account_id")
  invitedBy    String           @map("invited_by")
  invitedEmail String?          @map("invited_email")
  inviteCode   String           @unique @map("invite_code")
  role         AccountRole      @default(editor)
  status       InvitationStatus @default(pending)
  expiresAt    DateTime         @map("expires_at")
  acceptedBy   String?          @map("accepted_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([inviteCode])
  @@index([invitedEmail])
  @@map("account_invitations")
}

model Category {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  accountId   String?  @map("account_id")
  name        String
  icon        String?
  color       String?
  type        String   @default("expense")
  isSystem    Boolean  @default(false) @map("is_system")
  parentId    String?  @map("parent_id")
  embedding            Json?    @map("embedding")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  expenses Expense[]
  incomes  Income[]
  expenseCategorySplits ExpenseCategorySplit[]
  budgetCategories      BudgetCategory[]
  userSubscriptions     UserSubscription[]
  merchantCategoryRules MerchantCategoryRule[]

  @@unique([accountId, name, type])
  @@map("categories")
}

model Expense {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  accountId    String   @map("account_id")
  clientId     String   @map("client_id")
  categoryId   String?  @map("category_id")
  amount         Decimal  @db.Decimal(12, 2)
  discountAmount Decimal? @map("discount_amount") @db.Decimal(12, 2)
  currencyCode   String   @default("USD") @map("currency_code")
  description  String?
  notes        String?
  merchant     String?
  date         DateTime @db.Date
  time         String?
  locationLat  Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng  Decimal? @map("location_lng") @db.Decimal(11, 8)
  receiptUrl   String?  @map("receipt_url")
  isRecurring     Boolean  @default(false) @map("is_recurring")
  recurringId     String?  @map("recurring_id")
  recurringPeriod String?  @map("recurring_period")
  source       String   @default("manual")
  externalRef  String?  @map("external_ref")
  importBatchId String? @map("import_batch_id")
  isDebt           Boolean   @default(false) @map("is_debt")
  isDebtRepayment  Boolean   @default(false) @map("is_debt_repayment")
  debtContactName  String?   @map("debt_contact_name")
  debtDueDate      DateTime? @map("debt_due_date") @db.Date
  relatedDebtIncomeId String? @map("related_debt_income_id")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  syncVersion  Int      @default(0) @map("sync_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")

  receiptImage     Bytes?  @map("receipt_image")
  receiptMimeType  String? @map("receipt_mime_type")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id])
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])
  items    ExpenseItem[]
  expenseTags      ExpenseTag[]
  categorySplits   ExpenseCategorySplit[]
  projectExpenses  ProjectExpense[]

  @@unique([accountId, clientId])
  @@unique([accountId, externalRef])
  @@index([accountId, date(sort: Desc)])
  @@index([categoryId])
  @@index([accountId, isDebt])
  @@index([accountId, merchant])
  @@map("expenses")
}

model ExpenseItem {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("expense_items")
}

model Income {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  accountId    String   @map("account_id")
  clientId     String   @map("client_id")
  categoryId   String?  @map("category_id")
  amount       Decimal  @db.Decimal(12, 2)
  currencyCode String   @default("USD") @map("currency_code")
  description  String?
  notes        String?
  date         DateTime @db.Date
  source       String   @default("manual")
  externalRef  String?  @map("external_ref")
  importBatchId String? @map("import_batch_id")
  isDebt           Boolean   @default(false) @map("is_debt")
  isDebtRepayment  Boolean   @default(false) @map("is_debt_repayment")
  debtContactName  String?   @map("debt_contact_name")
  debtDueDate      DateTime? @map("debt_due_date") @db.Date
  relatedDebtExpenseId String? @map("related_debt_expense_id")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])
  incomeTags      IncomeTag[]
  projectIncomes  ProjectIncome[]
  linkedTransfer  AccountTransfer? @relation("TransferLinkedIncome")

  @@unique([accountId, clientId])
  @@unique([accountId, externalRef])
  @@index([accountId, date(sort: Desc)])
  @@index([categoryId])
  @@index([accountId, isDebt])
  @@map("incomes")
}

model Budget {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  accountId      String    @map("account_id")
  clientId       String    @map("client_id")
  name           String
  amount         Decimal   @db.Decimal(12, 2)
  currencyCode   String    @default("USD") @map("currency_code")
  period         String    @default("monthly")
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  alertThreshold Int       @default(80) @map("alert_threshold")
  isActive       Boolean   @default(true) @map("is_active")
  isDeleted            Boolean   @default(false) @map("is_deleted")
  syncVersion          Int       @default(0) @map("sync_version")
  encryptedPayload     String?   @map("encrypted_payload")
  encryptionKeyVersion Int?      @map("encryption_key_version")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  account             Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  alerts              BudgetAlert[]
  categoryAllocations BudgetCategory[]

  @@unique([accountId, clientId])
  @@index([accountId, isActive])
  @@map("budgets")
}

model BudgetCategory {
  id                   String   @id @default(uuid())
  budgetId             String   @map("budget_id")
  categoryId           String   @map("category_id")
  amount               Decimal  @db.Decimal(12, 2)
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([budgetId, categoryId])
  @@index([budgetId])
  @@index([categoryId])
  @@map("budget_categories")
}

model BudgetAlert {
  id                  String   @id @default(uuid())
  budgetId            String   @map("budget_id")
  userId              String   @map("user_id")
  thresholdPercentage Int      @map("threshold_percentage")
  triggeredAt         DateTime @map("triggered_at")
  periodStart         DateTime @map("period_start") @db.Date
  currentSpent        Decimal  @map("current_spent") @db.Decimal(12, 2)
  isRead              Boolean  @default(false) @map("is_read")
  notificationSent    Boolean  @default(false) @map("notification_sent")

  // Relations
  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([budgetId, thresholdPercentage, periodStart])
  @@map("budget_alerts")
}

model ChatConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  accountId String?  @map("account_id")
  isShared  Boolean  @default(false) @map("is_shared")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account?      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([accountId, updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id               String   @id @default(uuid())
  conversationId   String   @map("conversation_id")
  role             String
  content          String
  // Soft reference (no FK): preserves shared-chat history if the author is deleted; name resolved at read time
  senderUserId     String?  @map("sender_user_id")
  mentionedUserIds String[] @map("mentioned_user_ids")
  tokensUsed       Int?     @map("tokens_used")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model SyncLog {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  accountId          String?  @map("account_id")
  entityType         String   @map("entity_type")
  entityId           String   @map("entity_id")
  operation          String
  clientVersion      Int      @map("client_version")
  serverVersion      Int      @map("server_version")
  conflictResolved   Boolean  @default(false) @map("conflict_resolved")
  resolutionStrategy String?  @map("resolution_strategy")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("sync_log")
}

model WalletBalance {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  userId        String   @map("user_id")
  clientId      String   @map("client_id")
  currencyCode  String   @map("currency_code")
  initialAmount Decimal  @map("initial_amount") @db.Decimal(12, 2)
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, currencyCode])
  @@unique([accountId, clientId])
  @@index([accountId])
  @@map("wallet_balances")
}

model CurrencyExchange {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  userId       String   @map("user_id")
  clientId     String   @map("client_id")
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  fromAmount   Decimal  @map("from_amount") @db.Decimal(12, 2)
  toAmount     Decimal  @map("to_amount") @db.Decimal(12, 2)
  exchangeRate Decimal  @map("exchange_rate") @db.Decimal(12, 6)
  date         DateTime @db.Date
  notes        String?
  externalRef  String?  @map("external_ref")
  importBatchId String? @map("import_batch_id")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  syncVersion          Int      @default(0) @map("sync_version")
  encryptedPayload     String?  @map("encrypted_payload")
  encryptionKeyVersion Int?     @map("encryption_key_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@unique([accountId, clientId])
  @@unique([accountId, externalRef])
  @@index([accountId, date(sort: Desc)])
  @@map("currency_exchanges")
}

model AccountTransfer {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  clientId      String   @map("client_id")
  fromAccountId String   @map("from_account_id")
  fromCurrency  String   @map("from_currency")
  fromAmount    Decimal  @map("from_amount") @db.Decimal(12, 2)
  toAccountId   String   @map("to_account_id")
  toCurrency    String   @map("to_currency")
  toAmount      Decimal  @map("to_amount") @db.Decimal(12, 2)
  exchangeRate  Decimal  @map("exchange_rate") @db.Decimal(12, 6)
  date           DateTime @db.Date
  notes          String?
  countAsIncome  Boolean  @default(false) @map("count_as_income")
  linkedIncomeId String?  @unique @map("linked_income_id")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  syncVersion    Int      @default(0) @map("sync_version")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount  Account @relation("TransfersOut", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount    Account @relation("TransfersIn", fields: [toAccountId], references: [id], onDelete: Cascade)
  linkedIncome Income? @relation("TransferLinkedIncome", fields: [linkedIncomeId], references: [id])

  @@unique([userId, clientId])
  @@index([userId, date(sort: Desc)])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("account_transfers")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)

  // Stripe fields
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")

  // Billing period
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")

  // Trial
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")

  // Usage tracking
