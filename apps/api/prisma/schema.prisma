generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

enum AccountType {
  personal
  business
  shared
}

enum AccountRole {
  owner
  editor
  viewer
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

enum SubscriptionTier {
  free
  pro
  business
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  incomplete
  trialing
  paused
}

// ---- Models ----

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  name             String
  currencyCode     String    @default("USD") @map("currency_code")
  timezone         String    @default("UTC")
  pushToken            String?   @map("push_token")
  notifyBudgetAlerts   Boolean   @default(true) @map("notify_budget_alerts")
  notifySharedActivity Boolean   @default(true) @map("notify_shared_activity")
  isActive             Boolean   @default(true) @map("is_active")
  defaultAccountId String?   @map("default_account_id")
  lastSyncAt       DateTime? @map("last_sync_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  expenses          Expense[]
  incomes           Income[]
  budgets           Budget[]
  categories        Category[]
  chatConversations ChatConversation[]
  budgetAlerts      BudgetAlert[]
  syncLogs          SyncLog[]
  ownedAccounts     Account[]          @relation("OwnedAccounts")
  accountMembers    AccountMember[]
  walletBalances    WalletBalance[]
  currencyExchanges CurrencyExchange[]
  subscription      Subscription?
  usageLogs         UsageLog[]
  achievements      UserAchievement[]
  streaks           UserStreak[]

  @@map("users")
}

model Account {
  id           String      @id @default(uuid())
  name         String
  type         AccountType
  currencyCode String      @default("USD") @map("currency_code")
  ownerId      String      @map("owner_id")
  icon         String?
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  owner       User                @relation("OwnedAccounts", fields: [ownerId], references: [id], onDelete: Cascade)
  members     AccountMember[]
  invitations AccountInvitation[]
  expenses    Expense[]
  incomes     Income[]
  budgets     Budget[]
  categories        Category[]
  syncLogs          SyncLog[]
  walletBalances    WalletBalance[]
  currencyExchanges CurrencyExchange[]
  usageLogs         UsageLog[]
  generatedInsights GeneratedInsight[]
  spendingStories   SpendingStory[]
  tags              Tag[]
  projects          Project[]
  achievements      UserAchievement[]
  streaks           UserStreak[]

  @@map("accounts")
}

model AccountMember {
  id        String      @id @default(uuid())
  accountId String      @map("account_id")
  userId    String      @map("user_id")
  role      AccountRole
  joinedAt  DateTime    @default(now()) @map("joined_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("account_members")
}

model AccountInvitation {
  id           String           @id @default(uuid())
  accountId    String           @map("account_id")
  invitedBy    String           @map("invited_by")
  invitedEmail String?          @map("invited_email")
  inviteCode   String           @unique @map("invite_code")
  role         AccountRole      @default(editor)
  status       InvitationStatus @default(pending)
  expiresAt    DateTime         @map("expires_at")
  acceptedBy   String?          @map("accepted_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([inviteCode])
  @@index([invitedEmail])
  @@map("account_invitations")
}

model Category {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  accountId   String?  @map("account_id")
  name        String
  icon        String?
  color       String?
  type        String   @default("expense")
  isSystem    Boolean  @default(false) @map("is_system")
  parentId    String?  @map("parent_id")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  expenses Expense[]
  incomes  Income[]
  budgets  Budget[]
  expenseCategorySplits ExpenseCategorySplit[]

  @@unique([accountId, name, type])
  @@map("categories")
}

model Expense {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  accountId    String   @map("account_id")
  clientId     String   @map("client_id")
  categoryId   String?  @map("category_id")
  amount         Decimal  @db.Decimal(12, 2)
  discountAmount Decimal? @map("discount_amount") @db.Decimal(12, 2)
  currencyCode   String   @default("USD") @map("currency_code")
  description  String?
  notes        String?
  date         DateTime @db.Date
  time         String?
  locationLat  Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng  Decimal? @map("location_lng") @db.Decimal(11, 8)
  receiptUrl   String?  @map("receipt_url")
  isRecurring  Boolean  @default(false) @map("is_recurring")
  recurringId  String?  @map("recurring_id")
  source       String   @default("manual")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  syncVersion  Int      @default(0) @map("sync_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  receiptImage Bytes? @map("receipt_image")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id])
  items    ExpenseItem[]
  expenseTags      ExpenseTag[]
  categorySplits   ExpenseCategorySplit[]
  projectExpenses  ProjectExpense[]

  @@unique([accountId, clientId])
  @@index([accountId, date(sort: Desc)])
  @@index([categoryId])
  @@map("expenses")
}

model ExpenseItem {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("expense_items")
}

model Income {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  accountId    String   @map("account_id")
  clientId     String   @map("client_id")
  categoryId   String?  @map("category_id")
  amount       Decimal  @db.Decimal(12, 2)
  currencyCode String   @default("USD") @map("currency_code")
  description  String?
  notes        String?
  date         DateTime @db.Date
  isDeleted    Boolean  @default(false) @map("is_deleted")
  syncVersion  Int      @default(0) @map("sync_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  incomeTags      IncomeTag[]
  projectIncomes  ProjectIncome[]

  @@unique([accountId, clientId])
  @@index([accountId, date(sort: Desc)])
  @@index([categoryId])
  @@map("incomes")
}

model Budget {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  accountId      String    @map("account_id")
  clientId       String    @map("client_id")
  name           String
  amount         Decimal   @db.Decimal(12, 2)
  currencyCode   String    @default("USD") @map("currency_code")
  period         String    @default("monthly")
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  categoryId     String?   @map("category_id")
  alertThreshold Int       @default(80) @map("alert_threshold")
  isActive       Boolean   @default(true) @map("is_active")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  syncVersion    Int       @default(0) @map("sync_version")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id])
  alerts   BudgetAlert[]

  @@unique([accountId, clientId])
  @@index([accountId, isActive])
  @@map("budgets")
}

model BudgetAlert {
  id                  String   @id @default(uuid())
  budgetId            String   @map("budget_id")
  userId              String   @map("user_id")
  thresholdPercentage Int      @map("threshold_percentage")
  triggeredAt         DateTime @map("triggered_at")
  currentSpent        Decimal  @map("current_spent") @db.Decimal(12, 2)
  isRead              Boolean  @default(false) @map("is_read")
  notificationSent    Boolean  @default(false) @map("notification_sent")

  // Relations
  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("budget_alerts")
}

model ChatConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String
  tokensUsed     Int?     @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model SyncLog {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  accountId          String?  @map("account_id")
  entityType         String   @map("entity_type")
  entityId           String   @map("entity_id")
  operation          String
  clientVersion      Int      @map("client_version")
  serverVersion      Int      @map("server_version")
  conflictResolved   Boolean  @default(false) @map("conflict_resolved")
  resolutionStrategy String?  @map("resolution_strategy")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("sync_log")
}

model WalletBalance {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  userId        String   @map("user_id")
  clientId      String   @map("client_id")
  currencyCode  String   @map("currency_code")
  initialAmount Decimal  @map("initial_amount") @db.Decimal(12, 2)
  isDeleted     Boolean  @default(false) @map("is_deleted")
  syncVersion   Int      @default(0) @map("sync_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, currencyCode])
  @@unique([accountId, clientId])
  @@index([accountId])
  @@map("wallet_balances")
}

model CurrencyExchange {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  userId       String   @map("user_id")
  clientId     String   @map("client_id")
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  fromAmount   Decimal  @map("from_amount") @db.Decimal(12, 2)
  toAmount     Decimal  @map("to_amount") @db.Decimal(12, 2)
  exchangeRate Decimal  @map("exchange_rate") @db.Decimal(12, 6)
  date         DateTime @db.Date
  notes        String?
  isDeleted    Boolean  @default(false) @map("is_deleted")
  syncVersion  Int      @default(0) @map("sync_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, clientId])
  @@index([accountId, date(sort: Desc)])
  @@map("currency_exchanges")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)

  // Stripe fields
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")

  // Billing period
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")

  // Trial
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")

  // Usage tracking
  aiRequestsUsed      Int                @default(0) @map("ai_requests_used")
  aiRequestsResetAt   DateTime           @default(now()) @map("ai_requests_reset_at")

  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  subscriptionId String   @map("subscription_id")
  accountId      String?  @map("account_id")
  featureType    String   @map("feature_type")
  costUnits      Float    @map("cost_units")
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([accountId, userId, createdAt])
  @@map("usage_logs")
}

model GeneratedInsight {
  id               String   @id @default(uuid())
  accountId        String   @map("account_id")
  insightType      String   @map("insight_type")
  title            String
  description      String
  severity         String
  chartConfig      Json     @map("chart_config") @db.JsonB
  actionSuggestion String?  @map("action_suggestion")
  periodStart      DateTime @map("period_start") @db.Date
  periodEnd        DateTime @map("period_end") @db.Date
  isExpired        Boolean  @default(false) @map("is_expired")
  createdAt        DateTime @default(now()) @map("created_at")
  expiresAt        DateTime @map("expires_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, isExpired, createdAt])
  @@map("generated_insights")
}

model SpendingStory {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  periodLabel String   @map("period_label")
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  blocks      Json     @db.JsonB
  summary     String
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, periodStart, periodEnd])
  @@index([accountId, createdAt])
  @@map("spending_stories")
}

// ---- Tags ----

model Tag {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  name        String
  color       String?
  icon        String?
  usageCount  Int      @default(0) @map("usage_count")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expenseTags ExpenseTag[]
  incomeTags  IncomeTag[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("tags")
}

model ExpenseTag {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  tagId       String   @map("tag_id")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([expenseId, tagId])
  @@index([expenseId])
  @@index([tagId])
  @@map("expense_tags")
}

model IncomeTag {
  id          String   @id @default(uuid())
  incomeId    String   @map("income_id")
  tagId       String   @map("tag_id")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  income Income @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([incomeId, tagId])
  @@index([incomeId])
  @@index([tagId])
  @@map("income_tags")
}

// ---- Projects ----

model Project {
  id           String    @id @default(uuid())
  accountId    String    @map("account_id")
  clientId     String    @map("client_id")
  name         String
  description  String?
  color        String?
  icon         String?
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  budget       Decimal?  @db.Decimal(12, 2)
  currencyCode String?   @map("currency_code")
  isArchived   Boolean   @default(false) @map("is_archived")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  syncVersion  Int       @default(0) @map("sync_version")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  projectExpenses ProjectExpense[]
  projectIncomes  ProjectIncome[]

  @@unique([accountId, clientId])
  @@unique([accountId, name])
  @@index([accountId, isArchived])
  @@map("projects")
}

model ProjectExpense {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  expenseId   String   @map("expense_id")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([projectId, expenseId])
  @@index([projectId])
  @@index([expenseId])
  @@map("project_expenses")
}

model ProjectIncome {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  incomeId    String   @map("income_id")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  income  Income  @relation(fields: [incomeId], references: [id], onDelete: Cascade)

  @@unique([projectId, incomeId])
  @@index([projectId])
  @@index([incomeId])
  @@map("project_incomes")
}

// ---- Expense Category Splits ----

model ExpenseCategorySplit {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(12, 2)
  percentage  Decimal  @db.Decimal(5, 2)
  notes       String?
  isDeleted   Boolean  @default(false) @map("is_deleted")
  syncVersion Int      @default(0) @map("sync_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  expense  Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([expenseId])
  @@index([categoryId])
  @@map("expense_category_splits")
}

// ---- Gamification ----

model UserAchievement {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  accountId     String    @map("account_id")
  achievementId String    @map("achievement_id")
  progress      Int       @default(0)
  isCompleted   Boolean   @default(false) @map("is_completed")
  unlockedAt    DateTime? @map("unlocked_at")
  notified      Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId, achievementId])
  @@index([accountId, userId])
  @@map("user_achievements")
}

model UserStreak {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  accountId        String   @map("account_id")
  streakType       String   @default("daily_tracking") @map("streak_type")
  currentStreak    Int      @default(0) @map("current_streak")
  longestStreak    Int      @default(0) @map("longest_streak")
  lastActivityDate DateTime @map("last_activity_date") @db.Date
  streakStartDate  DateTime @map("streak_start_date") @db.Date
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId, streakType])
  @@map("user_streaks")
}
