{
  "expo": {
    "name": "AI Budget Assistant",
    "slug": "ai-budget-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "budget",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.budget.assistant",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record voice expenses.",
        "NSFaceIDUsageDescription": "This app uses Face ID to secure your financial data."
      }
    },
    "android": {
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.budget.assistant",
      "permissions": [
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "DETECT_SCREEN_CAPTURE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice expense entry."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-sqlite",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#4ECDC4"
        }
      ],
      "expo-web-browser",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BudgetWidgetSmall",
              "label": "Budget - Today",
              "minWidth": "110dp",
              "minHeight": "40dp",
              "description": "Shows today's spending total",
              "previewImage": "./assets/widget-small-preview.png",
              "resizeMode": "none",
                            "updatePeriodMillis": 1800000,
              "taskHandlerName": "BUDGET_WIDGET_TASK_HANDLER"
            },
            {
              "name": "BudgetWidgetMedium",
              "label": "Budget - Week",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "Shows weekly spending chart and today's total",
              "previewImage": "./assets/widget-medium-preview.png",
              "resizeMode": "horizontal",
                            "updatePeriodMillis": 1800000,
              "taskHandlerName": "BUDGET_WIDGET_TASK_HANDLER"
            },
            {
              "name": "BudgetWidgetLarge",
              "label": "Budget - Overview",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "description": "Shows budget progress and top categories",
              "previewImage": "./assets/widget-large-preview.png",
              "resizeMode": "horizontal|vertical",
                            "updatePeriodMillis": 1800000,
              "taskHandlerName": "BUDGET_WIDGET_TASK_HANDLER"
            },
            {
              "name": "QuickActionWidget",
              "label": "Budget - Quick Add",
              "minWidth": "250dp",
              "minHeight": "60dp",
              "description": "Quick buttons to add expenses by voice, scan, or manually",
              "previewImage": "./assets/widget-quickaction-preview.png",
              "resizeMode": "none",
                            "updatePeriodMillis": 0,
              "taskHandlerName": "BUDGET_WIDGET_TASK_HANDLER"
            }
          ]
        }
      ]
    ],
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49256da4-747d-43c9-8a21-fe6ff28a7497"
      }
    },
    "owner": "mi-code"
  }
}
