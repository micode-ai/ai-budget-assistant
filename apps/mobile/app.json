{
  "expo": {
    "name": "AI Budget Assistant",
    "slug": "ai-budget-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "budget",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4ECDC4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.budget.assistant",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record voice expenses.",
        "NSFaceIDUsageDescription": "This app uses Face ID to secure your financial data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4ECDC4"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.budget.assistant",
      "permissions": [
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "DETECT_SCREEN_CAPTURE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice expense entry."
        }
      ],
      "expo-sqlite",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#4ECDC4"
        }
      ],
      "expo-web-browser"
    ],
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49256da4-747d-43c9-8a21-fe6ff28a7497"
      }
    },
    "owner": "mi-code"
  }
}
