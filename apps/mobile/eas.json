{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.ai-budget.pl/api/v1",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "587710971480-l2noql6vqb8bikcfc0ef3juom9h51gbi.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "587710971480-2sc9b42b8f6tbq9ee9pat3ivc24nt7kd.apps.googleusercontent.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.ai-budget.pl/api/v1",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "587710971480-l2noql6vqb8bikcfc0ef3juom9h51gbi.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "587710971480-2sc9b42b8f6tbq9ee9pat3ivc24nt7kd.apps.googleusercontent.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
