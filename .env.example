# Backend API
DATABASE_URL=postgresql://user:password@localhost:5432/budget_assistant
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins (e.g. https://app.ai-budget.pl,https://admin.ai-budget.pl)
# Leave unset for local dev (defaults to localhost:8081 and localhost:3001)
CORS_ORIGIN=

# Admin access
ADMIN_EMAILS=admin@example.com

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
# Secret token passed to Telegram setWebhook (required in production webhook mode)
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_PHONE_NUMBER=
WHATSAPP_API_VERSION=v21.0

# Mobile app
EXPO_PUBLIC_API_URL=http://localhost:3000/api
